<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_nyp_background"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">


    <ImageView
        android:id="@+id/nypLogo"
        android:layout_width="419dp"
        android:layout_height="167dp"
        android:layout_marginTop="0dp"
        android:background="@android:color/white"
        android:contentDescription="@string/nyp_logo"
        android:src="@drawable/img_nyp_logo" />

    <TextView
        android:id="@+id/yesOrNoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/drawable_first_page"
        android:padding="12dp"
        android:text="@string/am_i_at_home_base"
        android:textSize="50sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">


        <Button
            android:id="@+id/noButton"
            android:layout_width="0dp"
            android:layout_height="223dp"
            android:layout_weight="1"
            android:background="@drawable/button_red_transparent"
            android:padding="12dp"
            android:text="@string/no"
            android:textColor="@color/black"
            android:textSize="40sp" />

        <Button
            android:id="@+id/yesButton"
            android:layout_width="0dp"
            android:layout_height="223dp"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:background="@drawable/button_turquoise_transparent"
            android:padding="12dp"
            android:text="@string/yes"
            android:textColor="@color/black"
            android:textSize="40sp" />
    </LinearLayout>


</LinearLayout>
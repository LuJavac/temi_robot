<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/fragment_container"
    android:background="@drawable/img_nyp_background"
    android:gravity="left"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/nypLogo"
            android:layout_width="420dp"
            android:layout_height="151dp"
            android:background="@android:color/white"
            android:contentDescription="@string/nyp_logo"
            android:src="@drawable/img_nyp_logo"
            android:layout_alignParentStart="true" />

        <ImageButton
            android:id="@+id/timeButton"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_alignTop="@id/nypLogo"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="200dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/time_settings"
            android:src="@drawable/drawable_hourglass"
            app:tint="@android:color/black"
            tools:ignore="RelativeOverlap"
            android:shadowColor="#00000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="1"
            />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_alignTop="@id/nypLogo"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="100dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/settings"
            android:src="@drawable/drawable_settings"
            app:tint="@android:color/black"
            tools:ignore="RelativeOverlap"
            android:shadowColor="#00000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="1"
            />
    </RelativeLayout>

    <Button
        android:id="@+id/interactionButton"
        android:layout_width="1029dp"
        android:layout_height="390dp"
        android:layout_gravity="center"
        android:layout_marginHorizontal="50dp"
        android:layout_marginTop="100dp"
        android:background="@drawable/button_blue_transparent"
        android:shadowColor="#80000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="1"
        android:text="@string/ask_me_something"
        android:textColor="@android:color/white"
        android:textSize="75sp" />

</LinearLayout>

<FrameLayout
    android:id="@+id/helloOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Hello !"
        android:textColor="#FFFFFF"
        android:textSize="220sp"
        android:textStyle="bold" />
</FrameLayout>

</FrameLayout>